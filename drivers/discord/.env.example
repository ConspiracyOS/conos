# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Optional: restrict to a specific channel (guild install).
# Leave empty for DM mode (bot responds to direct messages).
DISCORD_CHANNEL_ID=

# SSH connection to the conspiracy container
# (Old CON_SSH_* names still work as fallback)
CONOS_SSH_HOST=localhost
CONOS_SSH_PORT=22
CONOS_SSH_USER=root
CONOS_SSH_KEY=~/.ssh/id_ed25519
